# Required
DATABASE_URL=postgresql+psycopg://mise:mise@localhost:5432/mise

# URL of your Plex Media Server. Default port is 32400. For a server on
# the same LAN, an mDNS/hostname like http://plex.local:32400 or the LAN
# IP works fine. Plex's own remote-access docs:
#   https://support.plex.tv/articles/200289506-remote-access/
PLEX_BASE_URL=http://plex.local:32400

# Static X-Plex-Token for the account whose library you want to browse.
# Sign in to Plex Web, open any item, View XML, and copy the token from
# the URL. Step-by-step:
#   https://support.plex.tv/articles/204059436-finding-an-authentication-token-x-plex-token/
PLEX_TOKEN=replace-me

# Anthropic API key (powers the agentic recommendation loop). Create one
# at the Anthropic Console — needs an account with billing enabled:
#   https://console.anthropic.com/settings/keys
# Pricing reference: https://www.anthropic.com/pricing
ANTHROPIC_API_KEY=sk-ant-replace-me

# Postgres credentials. Used by docker-compose to provision the database
# container AND interpolated into the in-container DATABASE_URL. If you
# change these, update DATABASE_URL above to match (the URL above is for
# running the backend OUTSIDE docker — `localhost:5432` reaches the
# compose-managed postgres container via its host port mapping).
POSTGRES_USER=mise
POSTGRES_PASSWORD=mise
POSTGRES_DB=mise

# Optional (defaults shown)
ANTHROPIC_MODEL=claude-sonnet-4-6
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384
PORT=8080
CATALOG_TTL_SECONDS=86400
MAX_RECOMMENDATIONS=10
MAX_LOOP_TURNS=8
MAX_TOOL_CALLS=24
LOG_LEVEL=INFO

# Comma-separated origins for CORS. "*" allows any origin — fine for local
# development, but set an explicit list in production
# (e.g. https://mise.example.com,https://mise-staging.example.com).
CORS_ORIGINS=*
